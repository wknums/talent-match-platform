# ── Required ──────────────────────────────────────
# Authentication (set AUTH_REQUIRED=true to enforce AAD JWT)
AUTH_REQUIRED=false
AAD_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
AAD_AUDIENCE=api://<client-id>

# ── Azure SQL (passwordless – no user/pass) ──────
SQL_SERVER=<your-server>.database.windows.net
SQL_DATABASE=awrplatform
SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
SQL_CONNECTION_TIMEOUT=30
SQL_COMMAND_TIMEOUT=60
SQL_MAX_RETRIES=6
SQL_BASE_DELAY_MS=500
SQL_MAX_DELAY_MS=60000

# ── Service Bus ───────────────────────────────────
SB_NAMESPACE=<your-namespace>.servicebus.windows.net
SB_QUEUE=engine-runs
SB_DLQ=engine-runs/$deadletterqueue

# ── Observability ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── APIM (used by Terraform, not runtime) ─────────
# Managed via Terraform variables; placing here for reference.
