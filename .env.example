# ── .env_prod ─ Production Environment on Azure ───────────────────────────────
# Used with:  infra/terraform/envs/prod
# Deploy via: .\infra\scripts\deploy.ps1 -EnvFile .env_prod -TfEnv prod

# ── Resource Reuse Flags ──────────────────────────────────────────────────────
# Set to TRUE to reference an existing resource; FALSE (or omit) to provision new.
AZ_STORAGE_REUSE=FALSE
AZ_APPINSIGHTS_REUSE=FALSE
AZ_SERVICE_BUS_REUSE=FALSE
AZ_KEY_VAULT_REUSE=FALSE
AZ_APIM_REUSE=FALSE
AZ_LOGANALYTICS_REUSE=FALSE
AZ_IDENTITIES_REUSE=FALSE

# ── Existing Resource Details (required when *_REUSE=TRUE) ────────────────────
# Storage
# AZ_STORAGE_NAME=ststorageshared
# AZ_STORAGE_RG=rg-shared

# Application Insights
# AZ_APPINSIGHTS_NAME=appi-shared
# AZ_APPINSIGHTS_RG=rg-shared

# Service Bus
# AZ_SERVICE_BUS_NAME=sb-shared
# AZ_SERVICE_BUS_RG=rg-shared

# Key Vault
# AZ_KEY_VAULT_NAME=kv-shared
# AZ_KEY_VAULT_RG=rg-shared

# APIM
# AZ_APIM_NAME=apim-shared
# AZ_APIM_RG=rg-shared

# Log Analytics
# AZ_LOGANALYTICS_NAME=law-shared
# AZ_LOGANALYTICS_RG=rg-shared

# Managed Identities
# AZ_IDENTITIES_API_NAME=id-shared-api
# AZ_IDENTITIES_FUNC_NAME=id-shared-func
# AZ_IDENTITIES_RG=rg-shared

# ── Runtime Configuration ─────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────
# Authentication (set AUTH_REQUIRED=true to enforce AAD JWT)
AUTH_REQUIRED=false
AAD_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
AAD_AUDIENCE=api://<client-id>

# ── Functions host (Durable) – FastAPI → Functions internal HTTP ─────────
FUNCTIONS_HOST_URL=http://localhost:7071
FUNCTIONS_HOST_KEY=
FUNCTIONS_HTTP_TIMEOUT_S=10

# ── Service Bus (Platform → Engine dispatch, Engine → Platform results) ───
# Platform publishes RunMessage to SB_RUNS_QUEUE; receives RunResultMessage
# from SB_RESULTS_QUEUE when ENGINE_REPORT_MODE=servicebus.
# Sequential / low-volume client↔engine traffic bypasses the platform entirely.
SB_NAMESPACE=<your-sb-namespace>
SB_RUNS_QUEUE=engine-runs
SB_RESULTS_QUEUE=engine-results
ENGINE_REPORT_MODE=servicebus
# Required by the SB-trigger binding (identity-based connection):
SbConnection__fullyQualifiedNamespace=<your-sb-namespace>.servicebus.windows.net

# ── Blob storage (CV refs + batch results – MI auth, no SAS) ──────────────
BLOB_ACCOUNT=<your-storage-account>
BLOB_CONTAINER=cv-uploads
BLOB_RESULTS_CONTAINER=batch-results

# ── Live progress projection (SignalR) ────────────────────────────────────
LIVE_PROGRESS_ENABLED=false
# Use SIGNALR_SERVICE_ENDPOINT for managed identity in Azure.
SIGNALR_SERVICE_ENDPOINT=
# Use SIGNALR_CONNECTION_STRING only for local/dev scenarios that do not have MI.
SIGNALR_CONNECTION_STRING=
SIGNALR_HUB_NAME=batch-progress
LIVE_PROGRESS_TARGET=batchProgress
LIVE_PROGRESS_GROUP_PREFIX=submission

# ── Observability ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── APIM (used by Terraform, not runtime) ─────────
# Managed via Terraform variables; placing here for reference.
