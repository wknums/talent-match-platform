project             = "awr"
environment         = "test"
location            = "eastus2"
tenant_id           = "<your-tenant-id>"
publisher_email     = "platform-team@example.com"

host_choice           = "webapp_container"
use_private_endpoints = false
enable_artifact_storage = true
batch_results_retention_days = 7
enable_live_progress = false
signalr_sku          = "Standard_S1"
signalr_capacity     = 1

apim_sku        = "Developer_1"
app_service_sku = "B2"
functions_sku   = "Y1"
service_bus_sku = "Standard"
sb_queue_name   = "engine-runs"

container_image = "ghcr.io/placeholder/awr-platform-api:latest"

tags = {
  team = "platform"
}

# ── Resource Reuse (set to true + provide names to reuse existing resources) ──
reuse_storage      = false
reuse_appinsights  = false
reuse_service_bus  = false
reuse_key_vault    = false
reuse_apim         = false
reuse_loganalytics = false
reuse_identities   = false
reuse_core_rg      = false
reuse_functions_storage = false
reuse_signalr      = false

# When reuse_* = true, uncomment and fill in the existing resource details:
# existing_core_rg_name         = "rg-shared"
# existing_storage_name     = "ststorageshared"
# existing_storage_rg       = "rg-shared" # optional when reusing the core RG
# existing_appinsights_name = "appi-shared"
# existing_appinsights_rg   = "rg-shared" # optional when reusing the core RG
# existing_service_bus_name = "sb-shared"
# existing_service_bus_rg   = "rg-shared" # optional when reusing the core RG
# existing_key_vault_name   = "kv-shared"
# existing_key_vault_rg     = "rg-shared" # optional when reusing the core RG
# existing_apim_name        = "apim-shared"
# existing_apim_rg          = "rg-shared" # optional when reusing the core RG
# existing_loganalytics_name = "law-shared"
# existing_loganalytics_rg   = "rg-shared" # optional when reusing the core RG
# existing_identities_api_name  = "id-shared-api"
# existing_identities_func_name = "id-shared-func"
# existing_identities_rg        = "rg-shared" # optional when reusing the core RG
# existing_functions_storage_name = "stsharedfunctions"
# existing_functions_storage_rg   = "rg-shared" # optional when reusing the core RG
# existing_signalr_name            = "signalr-shared"
# existing_signalr_rg              = "rg-shared" # optional when reusing the core RG
# functions_deployment_container_name = "app-package"
